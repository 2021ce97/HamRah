# HamRah Rider App - Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and should never be committed.

# The base URL of your Railway-deployed HamRah backend.
# Find this in your Railway project dashboard under the backend service's
# "Settings > Networking > Public Networking" section.
# Format: https://<your-railway-domain>.up.railway.app
EXPO_PUBLIC_API_URL=https://your-railway-domain.up.railway.app
